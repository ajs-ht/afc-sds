# Anthropic API key used to call Claude.
ANTHROPIC_API_KEY=sk-ant-...

# Claude model used for SDS extraction. Deployment-wide setting; changing it
# needs no code changes. claude-opus-4-8 (default) prioritizes accuracy;
# claude-sonnet-5 is a lower-cost alternative and also supports native
# image/PDF input. See README.md "モデルの選択" for tradeoffs to re-check
# (sampling params, Structured Outputs grammar-size limit) before switching.
MODEL_ID=claude-opus-4-8

# Shared secret clients must send in the X-API-Key header.
API_KEY=change-me

# Upload limits.
MAX_UPLOAD_MB=32
MAX_PDF_PAGES=50

# Max tokens Claude may generate for one extraction.
MAX_OUTPUT_TOKENS=24000

# Max extractions processed at the same time. Each extraction holds the file
# in memory across a minutes-long Claude call; beyond this limit requests get
# an immediate 503 server_busy (with Retry-After) instead of queueing.
MAX_CONCURRENT_EXTRACTIONS=8

# Automatic retries (with backoff) inside the Anthropic SDK for transient
# failures (429 / 5xx / connection errors). 0 disables retries.
ANTHROPIC_MAX_RETRIES=2

# Constrained decoding via Claude structured outputs (output_config.format).
# Off by default: the SDS schema currently exceeds the API's compiled-grammar
# limits (verified 2026-07), so requests would pay one 400 round-trip before
# falling back to the prompt-embedded schema. Safe to re-enable for a retest
# after Anthropic raises the limit — the fallback is automatic.
USE_STRUCTURED_OUTPUTS=false

LOG_LEVEL=INFO
# "text" (human-readable, default) or "json" (one JSON object per line).
LOG_FORMAT=text
